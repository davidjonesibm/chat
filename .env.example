# ── Backend (runtime) ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET=your-supabase-service-role-key
CORS_ORIGIN=*

# Push notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Frontend (build-time, passed as Docker build args) ─
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE=your-supabase-anon-key

# Optional: Override API / WebSocket URLs.
# When omitted the frontend defaults to window.location.origin.
# VITE_API_URL=https://your-domain.example.com
# VITE_WS_URL=wss://your-domain.example.com

# ── Docker Compose ─────────────────────────────────────
# Host port the frontend nginx container is exposed on
FRONTEND_PORT=8080
