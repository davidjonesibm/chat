{
  "name": "chat",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev:frontend": "pnpm --filter @chat/frontend dev",
    "dev:backend": "pnpm --filter @chat/backend serve",
    "dev:supabase": "pnpm --filter @chat/backend db-start",
    "dev:supabase:stop": "pnpm --filter @chat/backend db-stop",
    "local:types": "pnpm --filter @chat/backend db-types:local && pnpm format",
    "types": "pnpm --filter @chat/backend db-types && pnpm format",
    "supabase:push": "pnpm --filter @chat/backend db-push",
    "build:frontend": "pnpm --filter @chat/frontend build",
    "build:backend": "pnpm --filter @chat/backend build",
    "build": "pnpm -r --reporter=append-only run build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "test": "pnpm -r run test",
    "analyze": "ANALYZE=true pnpm --filter @chat/frontend build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "20.19.9",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/ui": "~4.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "esbuild": "^0.19.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jiti": "2.6.1",
    "jsdom": "~22.1.0",
    "postcss": "^8.5.8",
    "prettier": "~3.6.2",
    "rollup-plugin-visualizer": "^5.14.0",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vitest": "~4.0.0",
    "vue-tsc": "^2.2.8"
  },
  "dependencies": {
    "@fastify/autoload": "~6.0.3",
    "@fastify/sensible": "~6.0.2",
    "fastify": "~5.2.1",
    "fastify-plugin": "~5.0.1",
    "pinia": "^3.0.4",
    "pocketbase": "^0.26.8",
    "@fastify/websocket": "^11.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  }
}
