192.168.86.20:8443 {
    tls internal
    log

    # Cache-Control: service worker must never be cached
    @sw path /service-worker.js
    header @sw Cache-Control "no-cache, no-store, must-revalidate"

    # Cache-Control: HTML files must always revalidate
    @html path *.html
    header @html Cache-Control "no-cache"

    # Cache-Control: hashed assets are safe to cache forever
    @hashed path /assets/*
    header @hashed Cache-Control "public, max-age=31536000, immutable"

    root * /Users/david/projects/chat/dist/apps/frontend
    try_files {path} /index.html
    file_server
}
